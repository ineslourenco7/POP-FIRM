{
  "installCommand": "corepack enable && pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/public",
  "cleanUrls": false,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/checkout/:id",
      "destination": "/crypto-checkout.html?plan=:id",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
