{
  "installCommand": "corepack enable && pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/public",
  "cleanUrls": false,
  "trailingSlash": false,
  "github": {
    "silent": false
  },
  "redirects": [
    {
      "source": "/signup.html",
      "destination": "/sign-up/",
      "permanent": false
    },
    {
      "source": "/sign-up.html",
      "destination": "/sign-up/",
      "permanent": false
    }
  ],
 "rewrites": [
  {
    "source": "/api/(.*)",
    "destination": "/api"
  },
  {
    "source": "/((?!assets/|favicon.ico|robots.txt|api/).*)",
    "destination": "/index.html"
  }
]
}
