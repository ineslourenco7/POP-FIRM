{
  "installCommand": "corepack enable && pnpm install --frozen-lockfile=false",
  "buildCommand": "BASE_PATH=/ pnpm --filter @workspace/prop-firm run build",
  "outputDirectory": "artifacts/prop-firm/dist/public",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
