# POP-FIRM environment template
# Copy this file to .env locally or add these variables in your hosting provider.

# Required: PostgreSQL connection string.
# Example: postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DATABASE_URL=

# Required only when authentication is enabled.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: app base path. Keep / for normal domains.
BASE_PATH=/

# Runtime port. Most hosting providers inject PORT automatically.
PORT=3000

# Runtime mode.
NODE_ENV=production
